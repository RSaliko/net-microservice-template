{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.AspNetCore.DataProtection": "Error",
      "Yarp": "Warning"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning",
        "Microsoft.AspNetCore.DataProtection": "Error",
        "Yarp.ReverseProxy.Health": "Error"
      }
    },
    "Enrich": [ "FromLogContext" ],
    "WriteTo": [
      { "Name": "Console" }
    ]
  },
  "ReverseProxy": {
    "Routes": {
      "product-service-route": {
        "ClusterId": "product-service-cluster",
        "Match": {
          "Path": "/api/v1/products/{**remainder}"
        },
        "Timeout": "00:00:30"
      },
      "order-service-route": {
        "ClusterId": "order-service-cluster",
        "Match": {
          "Path": "/api/v1/orders/{**remainder}"
        },
        "Timeout": "00:00:30"
      },
      "order-weather-route": {
        "ClusterId": "order-service-cluster",
        "Match": {
          "Path": "/api/v1/weather/{**remainder}"
        },
        "Timeout": "00:00:30"
      },
      "product-swagger": {
        "ClusterId": "product-service-cluster",
        "Match": {
          "Path": "/swagger/product/{**remainder}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/swagger/product" },
          { "PathPrefix": "/swagger" }
        ]
      },
      "order-swagger": {
        "ClusterId": "order-service-cluster",
        "Match": {
          "Path": "/swagger/order/{**remainder}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/swagger/order" },
          { "PathPrefix": "/swagger" }
        ]
      }
    },
    "Clusters": {
      "product-service-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5170"
          }
        },
        "HealthCheck": {
          "Active": {
            "Enabled": true,
            "Interval": "00:00:30",
            "Timeout": "00:00:10",
            "Policy": "ConsecutiveFailures",
            "Path": "/health",
            "UnhealthyThreshold": 3
          }
        }
      },
      "order-service-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5084"
          }
        },
        "HealthCheck": {
          "Active": {
            "Enabled": true,
            "Interval": "00:00:30",
            "Timeout": "00:00:10",
            "Policy": "ConsecutiveFailures",
            "Path": "/health",
            "UnhealthyThreshold": 3
          }
        }
      }
    }
  }
}
