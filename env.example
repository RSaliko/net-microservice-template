# ============================================================================
# SQL Server Configuration
# ============================================================================
MSSQL_HOST=localhost
MSSQL_PORT=14333
MSSQL_SA_PASSWORD=Your_strong_Password123

# Database Names
ORDER_DB_NAME=OrderServiceDb
PRODUCT_DB_NAME=ProductServiceDb

# ============================================================================
# RabbitMQ Configuration
# ============================================================================
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672

# ============================================================================
# Redis Configuration
# ============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379

# ============================================================================
# Application Settings
# ============================================================================
ASPNETCORE_ENVIRONMENT=Development

# API Gateway Configuration
APIGATEWAY_PORT=3000

# OrderService Configuration
ORDERSERVICE_PORT=5001

# ProductService Configuration
PRODUCTSERVICE_PORT=5002

# ============================================================================
# Instructions:
# 1. Copy this file to .env (in the same directory)
# 2. Customize values as needed for your local environment
# 3. Run: docker-compose -f docker-compose.sqlserver.yml up -d
# 4. Services will be available on configured ports
# ============================================================================
# 3. .env will be ignored by git (see .gitignore)
# ============================================================================
